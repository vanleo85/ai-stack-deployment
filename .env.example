# HuggingFace model name or path (e.g. Qwen/Qwen3.5-9B, meta-llama/Llama-3-8B)
QWEN_MODEL=Qwen/Qwen3.5-9B

# Host port to expose the vLLM OpenAI-compatible API
QWEN_PORT=8000

# Internal container port for the vLLM server (must match the port in vLLM --port flag)
VLLM_PORT=8000

# HuggingFace access token for private/gated models (uncomment in docker-compose.yml to use)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
